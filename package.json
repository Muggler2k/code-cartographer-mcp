{
  "name": "code-cartographer-mcp",
  "version": "0.1.0",
  "description": "MCP server for static, codebase-only execution context mapping.",
  "type": "module",
  "bin": {
    "code-cartographer-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "slop": "node scripts/slop-check.mjs",
    "cli": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ignore": "^5.3.2",
    "tree-sitter-wasms": "^0.1.13",
    "typescript": "^5.9.3",
    "web-tree-sitter": "^0.20.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=20"
  },
